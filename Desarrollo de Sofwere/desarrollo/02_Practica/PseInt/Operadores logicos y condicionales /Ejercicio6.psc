Algoritmo Ejercicio_6
	Escribir "dime cual es el radio de la circunsferencia del tanque";
	Definir Rad Como Real
	Leer Rad
	definir Area Como Real
	definir Perimetro Como Real
	Area <- pi * Rad^2
	Perimetro  <- 2 * Pi * Rad
	Escribir " El area de su tanque es : " , Area " y el Perimetro de su tanque es : " Perimetro
	
FinAlgoritmo
